#include <stdio.h>

int main() {
    int n, i;
    int even_sum = 0, odd_sum = 0;

    // Input number
    printf("Enter a number: ");
    scanf("%d", &n);

    // Loop from 1 to n
    for(i = 1; i <= n; i++) {
        if(i % 2 == 0) {
            even_sum = even_sum + i;   // even numbers
        } else {
            odd_sum = odd_sum + i;    // odd numbers
        }
    }

    // Output result
    printf("Sum of even numbers = %d\n", even_sum);
    printf("Sum of odd numbers = %d\n", odd_sum);

    return 0;
}
