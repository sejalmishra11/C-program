#include <stdio.h>

int main() {
    int num, original, remainder, sum;

    printf("Armstrong numbers from 1 to 100 are:\n");

    for (num = 1; num <= 100; num++) {
        original = num;
        sum = 0;

        while (original != 0) {
            remainder = original % 10;
            sum = sum + (remainder * remainder * remainder);
            original = original / 10;
        }

        if (sum == num) {
            printf("%d ", num);
        }
    }

    return 0;
}
