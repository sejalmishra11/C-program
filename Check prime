#include <stdio.h>

int main() {
    int n, i, flag = 0;

    // Input number
    printf("Enter a number: ");
    scanf("%d", &n);

    // Check prime
    if(n <= 1) {
        printf("Not a Prime Number.\n");
    } else {
        for(i = 2; i <= n/2; i++) {
            if(n % i == 0) {
                flag = 1;
                break;
            }
        }

        if(flag == 0)
            printf("Prime Number.\n");
        else
            printf("Not a Prime Number.\n");
    }

    return 0;
}
