#include <stdio.h>

int main() {
    int n, i;

    // Take number of elements
    printf("Enter number of elements: ");
    scanf("%d", &n);

    int arr[n];

    // Input elements
    printf("Enter elements:\n");
    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Assume first element is min and max
    int min = arr[0];
    int max = arr[0];

    // Find min and max
    for(i = 1; i < n; i++) {
        if(arr[i] < min) {
            min = arr[i];
        }
        if(arr[i] > max) {
            max = arr[i];
        }
    }

    // Print result
    printf("Minimum = %d\n", min);
    printf("Maximum = %d", max);

    return 0;
}
